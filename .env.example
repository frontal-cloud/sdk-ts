# Frontal Cloud SDK Environment Variables
# Copy this file to .env and fill in your values

# Development
NODE_ENV=development

# Testing
CI=false

# Coverage reporting
COVERAGE_DIR=coverage

# Frontal Cloud Configuration
FRONTAL_CLOUD_API_KEY=your_api_key_here
FRONTAL_CLOUD_BASE_URL=https://api.frontal.cloud

# Optional: Override package registry
NPM_REGISTRY=https://registry.npmjs.org/

# Optional: Enable debug logging
DEBUG=false

# Optional: Custom timeout for API requests (in milliseconds)
API_TIMEOUT=30000

# Optional: Enable verbose logging
VERBOSE=false
